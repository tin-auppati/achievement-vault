# ====================================================================
# Achievement Vault - Exhaustive Open Source .gitignore
# ====================================================================

# 1. Environment Secrets
.env
.env.*
!.env.example
!.env.template

# 2. Go Binaries & Build Artifacts
/achievement-vault
/vault
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.*
*.coverprofile
profile.cov
bin/
obj/
dummy-build

# 3. Next.js & Node.js UI Frontend
ui/node_modules/
ui/.next/
ui/out/
ui/build/
ui/.pnp*
ui/.yarn/*
!ui/.yarn/patches
!ui/.yarn/plugins
!ui/.yarn/releases
!ui/.yarn/versions
ui/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 4. SQLite Database & Local Data
data/
*.db
*.db-journal
*.sqlite
*.sqlite3

# 5. OS & IDE Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?