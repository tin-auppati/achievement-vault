FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o achievement-vault main.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates sqlite-libs tzdata

WORKDIR /app
COPY --from=builder /app/achievement-vault ./vault

ENV VAULT_HOME=/app
EXPOSE 8001

ENTRYPOINT ["./vault", "serve"]
